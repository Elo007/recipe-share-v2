# Copy to .env locally if you want, or set these in your hosting platform's
# environment variables dashboard for deployment.

# Get this from https://dashboard.stripe.com/test/apikeys (use the TEST key,
# starts with sk_test_, not sk_live_). Without this set, the app still runs
# fine, you just can't actually buy paid recipes, "Unlock this recipe" will
# show a friendly error instead of crashing anything.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Needed in production so Stripe redirects back to the right frontend after
# checkout, and so CORS/cookies work across two different domains.
FRONTEND_URL=https://your-frontend-name.onrender.com
NODE_ENV=production

# Optional, but recommended in production: a long random string used to
# sign session cookies. Any value works, it just needs to be secret.
SESSION_SECRET=change-this-to-something-random
